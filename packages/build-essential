#!/usr/bin/env bash
set -euo pipefail

case "$(uname -s)" in
    Darwin)
        # clang provided by Xcode Command Line Tools
        command -v cc >/dev/null 2>&1 && { echo "  [skip] build-essential (cc already available)"; exit 0; }
        xcode-select --install
        ;;
    Linux)
        command -v gcc >/dev/null 2>&1 && { echo "  [skip] build-essential (already installed)"; exit 0; }
        sudo apt-get install -y build-essential
        ;;
    *)
        echo "Unsupported OS: $(uname -s)" >&2; exit 1
        ;;
esac
