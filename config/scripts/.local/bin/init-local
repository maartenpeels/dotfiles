#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/workspace.sh"

# Resolve base repo — must be run from inside a project repo (not -local)
resolve_project() {
  local git_root current_dir_name common_dir

  git_root="$(git rev-parse --show-toplevel 2>/dev/null)" ||
    die "Not inside a git repository."

  current_dir_name="$(basename "$git_root")"

  if [[ "$current_dir_name" == *-local ]]; then
    die "Already inside a -local repo. Run this from inside the main project repo."
  fi

  common_dir="$(git -C "$git_root" rev-parse --git-common-dir)"
  BASE_REPO_PATH="$(cd "$git_root" && cd "$common_dir/.." && pwd)"
  WORKSPACE_ROOT="$(dirname "$BASE_REPO_PATH")"
  LOCAL_DIR="$WORKSPACE_ROOT/$(basename "$BASE_REPO_PATH")-local"
}

resolve_project

[[ -d "$LOCAL_DIR" ]] && die "-local repo already exists at $LOCAL_DIR"

PROJECT_NAME="$(basename "$BASE_REPO_PATH")"

info "Creating $LOCAL_DIR..."
mkdir -p "$LOCAL_DIR/local/bin"

# stow ignore — prevent internal dirs from being symlinked into worktrees
cat >"$LOCAL_DIR/.stow-local-ignore" <<'EOF'
^\.git$
^\.stow-local-ignore$
^local$
^\.worktrees$
^README.*$
EOF

# bootstrap template
cat >"$LOCAL_DIR/local/bin/bootstrap" <<'EOF'
#!/usr/bin/env bash
set -e

WT_PATH="${1:?Usage: bootstrap <worktree-path>}"
cd "$WT_PATH"

echo "=== Project Bootstrap ==="
echo ""

echo "[1/?] Injecting local configurations..."
config install "$WT_PATH"

# Add project-specific steps below. Examples:
#
# echo "[2/?] Trusting mise configurations..."
# mise trust mise.toml
#
# echo "[3/?] Installing mise tools..."
# mise install
#
# echo "[4/?] Installing dependencies..."
# npm install

echo "Bootstrap complete!"
EOF
chmod +x "$LOCAL_DIR/local/bin/bootstrap"

# init git
git -C "$LOCAL_DIR" init --quiet
git -C "$LOCAL_DIR" add .
git -C "$LOCAL_DIR" commit --quiet -m "init: scaffold ${PROJECT_NAME}-local"

success "Created ${PROJECT_NAME}-local at $LOCAL_DIR"
echo >&2
info "Next steps:"
echo "  1. Edit $LOCAL_DIR/local/bin/bootstrap — add project-specific setup" >&2
echo "  2. Drop files into $LOCAL_DIR/ that should be stowed into each worktree" >&2
echo "     e.g. mise.local.toml, .claude/settings.local.json" >&2
echo "  3. Run: wt add <branch>  — creates a worktree and runs bootstrap" >&2
